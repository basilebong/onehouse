{
  "name": "onehouse",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "Elastic-2.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "hooks:install": "lefthook install",
    "dev": "concurrently -k -n srv,web -c blue,green \"bun --hot apps/server/src/index.ts\" \"pnpm --filter @onehouse/web dev\"",
    "build": "pnpm --filter @onehouse/web build",
    "typecheck": "tsc -b",
    "test": "bun test",
    "check": "biome check .",
    "check:source": "bun ./scripts/check-source.ts",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "auth:generate": "bunx @better-auth/cli generate --config better-auth.config.ts --output packages/core/src/server/auth/schema.ts",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun ./scripts/migrate.ts",
    "license:check": "pnpm dlx license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;Unlicense'"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "19.0.2",
    "bun-types": "1.3.0",
    "concurrently": "9.1.0",
    "lefthook": "2.1.6",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
