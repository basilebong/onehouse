# Public URL the browser sees. In local dev this is the Vite dev server
# (port 5173); it proxies /api/* and /mcp to the Hono server on $PORT.
# Better Auth uses this as the OAuth callback origin and the cookie scope.
BETTER_AUTH_URL=http://localhost:5173

# 32+ char random secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Google OAuth Client ID + Secret.
# See: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" of type "Web application".
# Authorized redirect URI for local dev:
#   http://localhost:5173/api/auth/callback/google
# Authorized JavaScript origin:
#   http://localhost:5173
GOOGLE_ID=
GOOGLE_SECRET=

# Comma-separated list of allowlisted Google account emails. Only addresses
# in this list can sign in. Matched case-insensitively after trimming.
# Example: ONEHOUSE_ALLOWED_EMAILS=basile@example.com,partner@example.com
ONEHOUSE_ALLOWED_EMAILS=

# Public Host header the MCP endpoint (/mcp) is reached at — the DNS-rebinding
# allowlist. The server always also allows the BETTER_AUTH_URL host and
# localhost:$PORT, so for local dev you can leave this as-is. In production set
# it to your public domain, e.g. MCP_HOST=onehouse.example.de
# Claude connects to https://$MCP_HOST/mcp; OAuth discovery + the /consent
# screen are served from BETTER_AUTH_URL.
MCP_HOST=localhost

DATABASE_PATH=./data/app.db

NODE_ENV=development
PORT=3000

STORAGE_BOX_KEY=
STORAGE_BOX_SECRET=
