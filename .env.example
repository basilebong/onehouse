# Copy to .env and fill in. Never commit .env.
# Production values are loaded by docker-compose from the VPS host.

# Better Auth
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Google OAuth + One Tap
GOOGLE_ID=
GOOGLE_SECRET=

# MCP — public host used for DNS-rebinding allowlist
MCP_HOST=localhost

# SQLite path (inside container: /data/app.db)
DATABASE_PATH=./data/app.db

# Runtime
NODE_ENV=development
PORT=3000

# Litestream (prod only)
STORAGE_BOX_KEY=
STORAGE_BOX_SECRET=
